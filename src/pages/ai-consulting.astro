---
// Standalone full-bleed page — does not use Layout/Cardsinside,
// because this page has its own bespoke section system that the
// generic Layout chrome would clip. Fonts (Druk, Forma) come from
// /public/fonts/ via the global @font-face declarations already in
// /public/global.css, so they work automatically.
import Footer from '../components/footer.astro';
import Metrika from '../components/metrika.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link rel="preload" href="/fonts/PacaembuVar-subset.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/MulishVar-subset.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/NormalidadVar-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/Druk.ttf" as="font" type="font/truetype" crossorigin />
  <link rel="preload" href="/fonts/Forma-Regular.woff" as="font" type="font/woff" crossorigin />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/icon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <meta property="og:url" content="https://sgordeev.xyz/ai-consulting/" />
  <meta property="og:title" content="AI Consulting — Sergey Gordeev" />
  <meta property="og:type" content="website" />
  <meta property="og:description" content="I help businesses find where AI can cut costs and save time — then build it with you. Operations audit, custom AI tools, workflow automation." />
  <meta property="og:image" content="/images/me_studio_wb.webp" />

  <meta name="msapplication-TileColor" content="#5cebdf" />
  <meta name="theme-color" content="#FFF7ED" />

  <title>AI Consulting — Sergey Gordeev</title>

  <link rel="stylesheet" href="/global.css" />

  <style is:global>
    :root {
      --bg: #FFF7ED;          /* matches existing bg-orange-50 */
      --bg-2: #F4EBDB;
      --ink: #0E1530;
      --ink-soft: rgba(14, 21, 48, 0.8);
      --ink-mute: rgba(14, 21, 48, 0.6);
      --ink-line: rgba(14, 21, 48, 0.13);
      --red: #FF3A1F;         /* matches site red */
      --red-soft: rgba(255, 58, 31, 0.12);
    }

    @font-face {
      font-family: 'Druk';
      src: url('/fonts/Druk.ttf') format('truetype');
      font-display: swap;
    }

    body.aic-page {
      max-width: none !important;
      padding: 0 !important;
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font-family: Forma, Verdana, Geneva, Tahoma, sans-serif;
      font-size: 17px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    .aic * { box-sizing: border-box; }
    .aic a { color: inherit; }
    .aic .display, .aic .druk { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; letter-spacing: -0.01em; line-height: 0.94; }
    .aic .mono { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 12px; letter-spacing: 0.06em; color: var(--ink-mute);  text-transform: uppercase; }
    .aic .container { max-width: 1320px; margin: 0 auto; padding: 0 56px; }
    @media (max-width: 780px) { .aic .container { padding: 0 24px; } }

    /* nav */
    .aic nav.top { display: flex; justify-content: space-between; align-items: center; padding: 32px 0; font-size: 15px; }
    .aic nav.top a { text-decoration: none; }
    .aic nav.top .back { display: inline-flex; align-items: center; gap: 10px; color: var(--ink); opacity: 0.85; }
    .aic nav.top .back .arr { display: inline-block; transform: translateX(0); transition: transform 0.2s; }
    .aic nav.top .back:hover .arr { transform: translateX(-4px); }
    .aic nav.top .right { display: flex; gap: 28px; color: var(--ink-mute); flex-wrap: wrap; }
    .aic nav.top .right a:hover { color: var(--ink); }
    .aic .back-short { display: none; }
    .aic .burger { display: none; background: none; border: none; cursor: pointer; padding: 8px; flex-direction: column; gap: 5px; }
    .aic .burger span { display: block; width: 22px; height: 2px; background: var(--ink); border-radius: 1px; }
    .aic .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 998; }
    .aic .sidebar-overlay.open { display: block; }
    .aic .sidebar { position: fixed; top: 0; right: -280px; width: 280px; height: 100%; background: var(--bg); z-index: 999; padding: 32px 28px; display: flex; flex-direction: column; gap: 24px; transition: right 0.3s ease; box-shadow: -4px 0 24px rgba(0,0,0,0.1); }
    .aic .sidebar.open { right: 0; }
    .aic .sidebar-close { align-self: flex-end; background: none; border: none; font-size: 28px; cursor: pointer; color: var(--ink); padding: 0; line-height: 1; }
    .aic .sidebar a { text-decoration: none; font-size: 18px; color: var(--ink); padding: 8px 0; border-bottom: 1px solid var(--ink-line); }
    @media (max-width: 780px) { .aic .back-full { display: none; } .aic .back-short { display: inline; } .aic nav.top .right { display: none; } .aic .burger { display: flex; } }

    /* hero */
    .aic .hero { position: relative; padding: 0px 0 96px; overflow: hidden; }
    .aic .hero .blob-1 { position: absolute; width: 520px; height: 520px; border-radius: 50%; background: var(--red); filter: blur(64px); opacity: 0.55; left: -180px; top: 120px; z-index: 0; pointer-events: none; display: none;}
    .aic .hero .blob-2 { position: absolute; width: 420px; height: 420px; right: -120px; top: 280px; z-index: 0; pointer-events: none; }
    .aic .hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.9fr); gap: 56px; align-items: end; }
    .aic .eyebrow { display: inline-flex; align-items: center; gap: 10px; color: var(--ink-mute); font-size: 13px; letter-spacing: 0.08em; margin-bottom: 28px;  text-transform: uppercase; }
    .aic .eyebrow .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); box-shadow: 0 0 0 4px var(--red-soft); }
    .aic h1.hero-title { font-size: clamp(56px, 9vw, 128px); color: var(--red); margin: 0 0 36px; font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; line-height: 0.92; }
    .aic .hero-lead { font-size: 22px; line-height: 1.4; max-width: 620px; color: var(--ink-soft); margin: 0 0 36px; }
    .aic .hero-lead em { font-style: normal; color: var(--ink); background: linear-gradient(180deg, transparent 60%, rgba(255, 58, 31, 0.2) 60%); padding: 0 2px; }
    .aic .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; }
    .aic .btn { display: inline-flex; align-items: center; gap: 10px; padding: 14px 22px; border-radius: 999px; text-decoration: none; font-weight: 500; font-size: 15px; border: 1px solid transparent; transition: transform 0.15s ease, background 0.15s ease; }
    .aic .btn:hover { transform: translateY(-1px); }
    .aic .btn.primary { background: var(--ink); color: var(--bg); }
    .aic .btn.primary:hover { background: #1a2240; }
    .aic .btn.ghost { background: transparent; color: var(--ink); border-color: var(--ink-line); }
    .aic .btn.ghost:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }
    .aic .hero-side { display: flex; flex-direction: column; gap: 18px; padding-bottom: 8px; }
    .aic .stat { display: grid; grid-template-columns: 90px 1fr; gap: 18px; padding: 18px 0; border-top: 1px solid var(--ink-line); }
    .aic .stat:last-child { border-bottom: 1px solid var(--ink-line); }
    .aic .stat .num { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 36px; color: var(--ink); line-height: 1; }
    .aic .stat .lbl { font-size: 14px; color: var(--ink-mute); align-self: center; }
    @media (max-width: 900px) { .aic .hero-grid { grid-template-columns: 1fr; gap: 32px; } .aic h1.hero-title { font-size: 64px; } .aic .hero-lead { font-size: 18px; } }
    @media (max-width: 780px) { .aic .hero .blob-2 { display: none; } .aic .cta .blob.b2 { display: none; } }

    /* marquee */
    .aic .marquee { position: relative; overflow: hidden; border-top: 1px solid var(--ink-line); border-bottom: 1px solid var(--ink-line); padding: 22px 0; background: var(--bg); }
    .aic .marquee-track { display: flex; gap: 48px; white-space: nowrap; animation: aic-scroll 10s linear infinite; font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 28px; color: var(--ink); }
    .aic .marquee-track > span { display: inline-flex; align-items: center; gap: 48px; flex-shrink: 0; }
    .aic .marquee-track .star { color: var(--red); font-size: 22px; }
    @keyframes aic-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* section base */
    .aic section.block { padding: 96px 0; border-top: 1px solid var(--ink-line); }
    .aic section.block.tight { padding: 72px 0; }
    .aic .section-head { display: grid; grid-template-columns: 200px 1fr; gap: 48px; margin-bottom: 64px; align-items: start; }
    .aic .section-head .label { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 12px; letter-spacing: 0.1em; color: var(--ink-mute); padding-top: 12px;  text-transform: uppercase; }
    .aic .section-head .label .sn { color: var(--red); margin-right: 8px; }
    .aic .section-head h2 { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: clamp(40px, 5.4vw, 72px); line-height: 0.95; margin: 0; max-width: 14ch; }
    .aic .section-head h2 .red { color: var(--red); }
    @media (max-width: 780px) { .aic .section-head { grid-template-columns: 1fr; gap: 16px; margin-bottom: 40px; } .aic section.block { padding: 72px 0; } }

    /* what-grid */
    .aic .what-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; }
    .aic .what { padding: 32px 0; border-top: 1px solid var(--ink-line); display: grid; grid-template-columns: 60px 1fr; gap: 24px; }
    .aic .what:nth-child(odd) { padding-right: 32px; }
    .aic .what:nth-child(even) { padding-left: 32px; border-left: 1px solid var(--ink-line); }
    .aic .what .n { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 28px; color: var(--red); }
    .aic .what h3 { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 24px; margin: 0 0 8px; }
    .aic .what p { margin: 0; color: var(--ink-soft); font-size: 15.5px; }
    @media (max-width: 780px) { .aic .what-grid { grid-template-columns: 1fr; } .aic .what:nth-child(odd), .aic .what:nth-child(even) { padding: 28px 0; border-left: none; } }

    /* packages */
    .aic .pkgs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .aic .pkg { position: relative; background: var(--bg-2); border-radius: 24px; padding: 32px; display: flex; flex-direction: column; gap: 18px; min-height: 560px; }
    .aic .pkg.feature { background: var(--ink); color: var(--bg); }
    .aic .pkg.feature .pkg-name, .aic .pkg.feature h3, .aic .pkg.feature li, .aic .pkg.feature .pkg-price small { color: var(--bg); }
    .aic .pkg.feature .pkg-meta { color: rgba(255, 247, 237, 0.7); }
    .aic .pkg.feature .pkg-divider { background: rgba(255, 247, 237, 0.15); }
    .aic .pkg.feature .check { background: var(--red); color: var(--bg); }
    .aic .pkg.feature .btn.primary { background: var(--red); color: var(--bg); }
    .aic .pkg.feature .btn.primary:hover { background: #ff5236; }
    .aic .pkg .badge { position: absolute; top: 20px; right: 20px; font-size: 11px; letter-spacing: 0.1em; background: var(--red); color: #fff; padding: 6px 10px; border-radius: 999px; font-weight: 600;  text-transform: uppercase; }
    .aic .pkg-name { font-family: ui-monospace, monospace; font-size: 12px; letter-spacing: 0.1em; color: var(--ink-mute);  text-transform: uppercase; }
    .aic .pkg h3 { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 34px; margin: 0; line-height: 1; }
    .aic .pkg-price { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 42px; line-height: 1; }
    .aic .pkg-price small { display: block; font-family: Forma, sans-serif; font-weight: 400; font-size: 13px; color: var(--ink-mute); margin-top: 6px; letter-spacing: 0; }
    .aic .pkg-meta { font-size: 14px; color: var(--ink-mute); }
    .aic .pkg-divider { height: 1px; background: var(--ink-line); }
    .aic .pkg ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; flex: 1; }
    .aic .pkg li { display: grid; grid-template-columns: 18px 1fr; gap: 12px; font-size: 14.5px; line-height: 1.45; color: var(--ink-soft); }
    .aic .pkg.feature li { color: rgba(255, 247, 237, 0.9); }
    .aic .check { width: 18px; height: 18px; border-radius: 50%; background: var(--ink); color: var(--bg); display: inline-flex; align-items: center; justify-content: center; font-size: 11px; flex-shrink: 0; margin-top: 2px; }
    @media (max-width: 900px) { .aic .pkgs { grid-template-columns: 1fr; } }

    /* process */
    .aic .process { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border-top: 1px solid var(--ink-line); }
    .aic .step { padding: 32px 24px; border-right: 1px solid var(--ink-line); position: relative; }
    .aic .step:first-child { padding-left: 0; }
    .aic .step:last-child { border-right: none; }
    .aic .step .n { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 64px; line-height: 1; color: var(--red); margin-bottom: 24px; }
    .aic .step h4 { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 20px; margin: 0 0 8px; }
    .aic .step .when { font-size: 12px; letter-spacing: 0.08em; color: var(--ink-mute); margin-bottom: 14px; font-family: ui-monospace, monospace;  text-transform: uppercase; }
    .aic .step p { margin: 0; color: var(--ink-soft); font-size: 14.5px; }
    @media (max-width: 900px) { .aic .process { grid-template-columns: 1fr 1fr; } .aic .step { border-right: 1px solid var(--ink-line); border-bottom: 1px solid var(--ink-line); } .aic .step:nth-child(2n) { border-right: none; } }
    @media (max-width: 560px) { .aic .process { grid-template-columns: 1fr; } .aic .step { border-right: none; } }

    /* fit */
    .aic .fit { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .aic .fit .col { padding: 28px 28px 32px; border-radius: 24px; background: var(--bg-2); border: 1px solid var(--ink-line); }
    .aic .fit .col.no { background: transparent; }
    .aic .fit h3 { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 24px; margin: 0; }
    .aic .fit .head-row { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
    .aic .fit .head-row .pill { font-family: ui-monospace, monospace; font-size: 11px; letter-spacing: 0.1em; padding: 5px 10px; border-radius: 999px; border: 1px solid var(--ink-line);  text-transform: uppercase; }
    .aic .fit .col.yes .pill { background: var(--ink); color: var(--bg); border-color: var(--ink); }
    .aic .fit ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
    .aic .fit li { display: grid; grid-template-columns: 20px 1fr; gap: 12px; font-size: 15px; color: var(--ink-soft); align-items: start; }
    .aic .fit .icn { display: inline-flex; align-items: center; justify-content: center; font-size: 14px; line-height: 1; margin-top: 1px; font-weight: 700; }
    .aic .fit .yes .icn { color: var(--red); }
    .aic .fit .no .icn { color: var(--ink-mute); }
    @media (max-width: 780px) { .aic .fit { grid-template-columns: 1fr; } }

    /* cases */
    .aic .cases { display: flex; flex-direction: column; }
    .aic .case { display: grid; grid-template-columns: 120px minmax(0, 1.4fr) minmax(0, 1fr); gap: 48px; padding: 36px 0; border-top: 1px solid var(--ink-line); align-items: start; }
    .aic .case:last-child { border-bottom: 1px solid var(--ink-line); }
    .aic .case .yr { font-family: ui-monospace, monospace; font-size: 13px; color: var(--ink-mute); padding-top: 8px; letter-spacing: 0.05em; }
    .aic .case h3 { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 34px; margin: 0 0 6px; line-height: 1; }
    .aic .case .role { font-size: 13px; color: var(--ink-mute); margin-bottom: 14px; font-family: ui-monospace, monospace; letter-spacing: 0.05em; }
    .aic .case p { margin: 0; color: var(--ink-soft); font-size: 15.5px; max-width: 50ch; }
    .aic .case .results { display: flex; flex-direction: column; gap: 14px; padding-top: 6px; }
    .aic .case .res { display: grid; grid-template-columns: auto 1fr; gap: 14px; align-items: baseline; }
    .aic .case .res .v { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 30px; color: var(--red); line-height: 1; }
    .aic .case .res .k { font-size: 13px; color: var(--ink-mute); max-width: 18ch; }
    @media (max-width: 900px) { .aic .case { grid-template-columns: 1fr; gap: 18px; } }

    /* stack */
    .aic .stack-wrap { position: relative; overflow: hidden; border-radius: 32px; background: var(--ink); color: var(--bg); padding: 56px 48px; }
    .aic .stack-wrap .blob { position: absolute; right: -100px; bottom: -100px; width: 380px; height: 380px; background: var(--red); filter: blur(64px); opacity: 0.55; border-radius: 50%; }
    .aic .stack-wrap h3 { position: relative; font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 36px; margin: 0 0 28px; }
    .aic .stack-grid { position: relative; display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .aic .chip { padding: 14px 18px; border: 1px solid rgba(255, 247, 237, 0.18); border-radius: 14px; font-size: 14px; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .aic .chip .k { color: rgba(255, 247, 237, 0.7); font-family: ui-monospace, monospace; font-size: 11px; letter-spacing: 0.08em;  text-transform: uppercase; }
    @media (max-width: 780px) { .aic .stack-wrap { padding: 40px 24px; } .aic .stack-grid { grid-template-columns: repeat(2, 1fr); } .aic .chip { flex-direction: column; align-items: flex-start; gap: 6px; } }

    /* quotes */
    .aic .quotes { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .aic .quote { padding: 32px; background: var(--bg-2); border-radius: 24px; display: flex; flex-direction: column; gap: 24px; }
    .aic .quote blockquote { margin: 0; font-size: 20px; line-height: 1.45; color: var(--ink); }
    .aic .quote blockquote::before { content: "\201C"; font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; color: var(--red); font-size: 48px; line-height: 0.5; display: block; margin-bottom: 8px; }
    .aic .quote .who { display: flex; align-items: center; gap: 14px; margin-top: auto; }
    .aic .quote .av { width: 42px; height: 42px; border-radius: 50%; background: repeating-linear-gradient(135deg, var(--ink-line) 0 6px, transparent 6px 12px), var(--bg); border: 1px solid var(--ink-line); display: flex; align-items: center; justify-content: center; font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; color: var(--ink); font-size: 15px; flex-shrink: 0; }
    .aic .quote .meta { font-size: 13.5px; line-height: 1.35; }
    .aic .quote .meta .nm { font-weight: 600; }
    .aic .quote .meta .rl { color: var(--ink-mute); }
    @media (max-width: 780px) { .aic .quotes { grid-template-columns: 1fr; } }

    /* faq */
    .aic .faq { display: flex; flex-direction: column; border-top: 1px solid var(--ink-line); }
    .aic details.q { border-bottom: 1px solid var(--ink-line); padding: 24px 0; cursor: pointer; }
    .aic details.q summary { list-style: none; display: grid; grid-template-columns: 1fr 24px; gap: 24px; align-items: center; font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: 22px; }
    .aic details.q summary::-webkit-details-marker { display: none; }
    .aic details.q summary .plus { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; color: var(--red); font-size: 28px; line-height: 1; transition: transform 0.25s; }
    .aic details.q[open] summary .plus { transform: rotate(45deg); }
    .aic details.q .ans { padding-top: 14px; color: var(--ink-soft); font-size: 16px; max-width: 75ch; }

    /* cta */
    .aic .cta { position: relative; overflow: hidden; border-radius: 32px; -webkit-mask-image: -webkit-radial-gradient(white, black); background: var(--bg-2); padding: 40px 56px; display: grid; grid-template-columns: 1.4fr 1fr; gap: 48px; align-items: center;}
    .aic .cta .blob { position: absolute; left: -160px; top: -160px; width: 480px; height: 480px; background: var(--red); filter: blur(64px); opacity: 0.5; border-radius: 50%; }
    .aic .cta .blob.b2 { left: auto; right: -100px; top: auto; bottom: -220px; width: 380px; height: 380px; background: none; filter: none; border-radius: 0; opacity: 1; }
    .aic .cta-inner { position: relative; z-index: 1; }
    .aic .cta h2 { font-family: 'Archivo', 'Druk', Tahoma, sans-serif; font-weight: 900; font-size: clamp(44px, 5.4vw, 68px); line-height: 0.95; margin: 0 0 20px; }
    .aic .cta h2 .red { color: var(--red); }
    .aic .cta p { margin: 0 0 28px; color: var(--ink-soft); font-size: 18px; max-width: 46ch; }
    .aic .cta .actions { display: flex; flex-wrap: wrap; gap: 12px; }
    .aic .cta-photo { position: relative; z-index: 1; align-self: stretch; margin-bottom: -40px; overflow: hidden; padding-top: 32px; }
    .aic .cta-photo img {  top: 0; left: 0; width: 100%; height: auto; max-height: 40vw; display: block; object-fit:contain;}
